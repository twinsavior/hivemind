{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist/modules/email",
    "rootDir": "src/modules/email",
    "declaration": true,
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "composite": true,
    "noEmit": false
  },
  "include": ["src/modules/email/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
