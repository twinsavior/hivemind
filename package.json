{
  "name": "hivemind-swarm",
  "version": "1.0.0-beta.1",
  "description": "AI-powered operations platform for e-commerce sellers — Amazon, Walmart, eBay",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "hivemind": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js up",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.1.0",
    "express": "^4.21.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "imapflow": "^1.2.16",
    "mailparser": "^3.9.5",
    "pdf-parse": "^2.4.5",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "ecommerce",
    "amazon-seller",
    "walmart",
    "ebay",
    "arbitrage",
    "multi-agent",
    "llm",
    "hivemind"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/twinsavior/hivemind.git"
  },
  "bugs": {
    "url": "https://github.com/twinsavior/hivemind/issues"
  },
  "homepage": "https://github.com/twinsavior/hivemind#readme",
  "files": [
    "dist",
    "hivemind.example.yaml",
    "README.md",
    "LICENSE"
  ]
}
