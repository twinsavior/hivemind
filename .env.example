# ============================================================================
# HIVEMIND Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.
# ============================================================================

# ── LLM Provider API Keys ─────────────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4, o1, embeddings)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Google (Gemini)
GOOGLE_API_KEY=

# Ollama (local models - no API key needed)
OLLAMA_HOST=http://localhost:11434

# ── Connector Tokens ──────────────────────────────────────────────────────────

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=

# Webhook
WEBHOOK_SECRET=
WEBHOOK_AUTH_TOKEN=

# ── Dashboard ──────────────────────────────────────────────────────────────────

DASHBOARD_PASSWORD=

# ── Storage ────────────────────────────────────────────────────────────────────

# Redis (only needed for distributed mode)
REDIS_URL=redis://localhost:6379

# ── Advanced ───────────────────────────────────────────────────────────────────

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Node environment
NODE_ENV=development
