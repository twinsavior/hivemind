{
  "name": "hivemind-desktop",
  "version": "1.0.0-beta.3",
  "description": "HIVEMIND Desktop – AI-powered operations manager for Amazon, Walmart & eBay sellers",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.hivemind.desktop",
    "productName": "HIVEMIND",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "server",
        "filter": ["**/*"]
      },
      {
        "from": "server-deps/node_modules",
        "to": "node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../skills",
        "to": "skills",
        "filter": ["**/*"]
      },
      {
        "from": "../package.json",
        "to": "package.json"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": ["dmg", "zip"],
      "icon": "icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    },
    "publish": [{
      "provider": "github",
      "owner": "twinsavior",
      "repo": "hivemind"
    }]
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
